# EditorConfig - https://editorconfig.org
# Aplicado por extensión EditorConfig.EditorConfig

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,cjs,mjs,json}]
indent_style = space
indent_size = 2

[*.sol]
indent_style = space
indent_size = 4

[*.{md,yml,yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
