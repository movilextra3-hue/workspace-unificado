# PRIVATE_KEY=
# NILE_API_KEY=
# MAINNET_API_KEY=

# ERC-20 / Tenderly (blockchain/token-erc20, tenderly_tools)
# TENDERLY_ACCESS_KEY=
# INFURA_KEY=
# PRIVATE_KEY=

# Solana (solana/555)
# SOLANA_PRIVATE_KEY_BASE58=
# SOLANA_DESTINO=
# SOLANA_RPC=

