  "dependencies": {
    "dotenv": "^16.3.1",
    "tronweb": "^5.3.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "playwright": "^1.58.2",
    "sharp": "^0.33.5",
    "solc": "0.8.25",
