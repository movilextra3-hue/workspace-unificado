    "lint:js": "eslint scripts migrations test tronbox.js --ext .js",
    "security-check": "npm run lint",
    "audit:readme": "echo Ver docs/vitacora/CONSOLIDACION_COMPLETA_TODO.md para Slither, MythX y checklist",
    "fix:eslint-e": "node scripts/instalar-eslintrc-en-E.js",
    "fix:pragma": "node scripts/fix-pragma-verification.js",
    "lint:all": "npm run lint:js && npm run lint && node scripts/lint-otros-proyectos.js"
