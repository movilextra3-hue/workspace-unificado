{
  "name": "workspace-unificado",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo con foco operativo TRC20/TRON en blockchain/trc20-token. ERC20 (lint), Solana, apps RTSP y blockchain/tenderly_tools son opcionales; Tenderly no forma parte del flujo npm install raíz (ver script install:tenderly-tools).",
  "scripts": {
    "sync": "node scripts/sync-desde-E.js",
    "sync:dry": "node scripts/sync-desde-E.js --dry-run",
    "fix:json-bom": "node scripts/fix-json-bom.js",
    "preflight": "node scripts/preflight.js",
    "check": "node scripts/fix-json-bom.js && node scripts/check-todo.js && npm run lint && npm run lint:py && npm run lint:md",
    "test:all": "npm run check && npm run test --workspace=trc20-token && npm run test --workspace=mi-token",
    "lint": "npm run lint:all -w trc20-token && npx solhint \"blockchain/token-erc20/contracts/**/*.sol\" --config blockchain/token-erc20/.solhint.json",
    "lint:py": "node scripts/lint-python.js",
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#**/node_modules/**\" \"#**/tools/binary/**\" \"#**/trc20-token-backup*/**\"",
    "postinstall": "node scripts/install-ruff.js && echo Ejecuta 'npm run sync' para poblar subproyectos desde E: si están vacíos.",
    "audit": "npm audit",
    "audit:fix": "npm audit fix --no-fund",
    "security:secrets": "node scripts/check-secrets.js",
    "verify:mcp-tronscan": "node scripts/verify-mcp-tronscan-integration.js",
    "install:tenderly-tools": "npm install --no-fund --prefix blockchain/tenderly_tools",
    "gallery": "node docs/vitacora/gallery-viewer/server.js",
    "fix:cursor": "powershell -ExecutionPolicy Bypass -File scripts/cerrar-cursor-y-fix-extensions.ps1",
    "crear:lanzador": "powershell -ExecutionPolicy Bypass -File scripts/crear-lanzador-escritorio.ps1",
    "sync:cursor-rules-global": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sync-cursor-global-rules.ps1"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.21.0"
  },
  "workspaces": [
    "blockchain/trc20-token",
    "blockchain/token-erc20"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
